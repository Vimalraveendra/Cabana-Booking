{
  "name": "cabana-booking",
  "version": "1.0.0",
  "description": "Interactive cabana booking website for luxury resorts.",
  "main": "index.js",
  "scripts": {
    "start": "npm run build:frontend && tsx backend/server.ts --map map.ascii  --bookings bookings.json",
    "build:frontend": "esbuild frontend/app.ts --bundle --outfile=frontend/app.js",
    "build": "tsc && npm run build:frontend",
    "test": "jest tests/",
    "test:backend": "jest tests/server.test.ts",
    "test:frontend": "jest tests/app.test.ts",
    "test:watch": "jest tests/ --watch"
  },
  "keywords": [],
  "author": "Vimal Raveendran",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
  "transform": {
  "^.+\\.tsx?$": ["ts-jest", {
    "tsconfig": "tsconfig.json"
  }]
}
  }
}
